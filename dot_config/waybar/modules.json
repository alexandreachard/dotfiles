{
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{name}",
    "format": "< %g >",
    "format_focused": "< %g тЧП >"
  },
  "sway/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true,
    "format": "{}",
    "max-lenghgt": 35
  },
  "tray": {
    // "icon-size": 14,
    "spacing": 5
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#bb9af7'><b>{}</b></span>", // Purple
        "days": "<span color='#7aa2f7'><b>{}</b></span>", // Blue
        "weeks": "<span color='#9ece6a'><b>W{}</b></span>", // Green
        "weekdays": "<span color='#e0af68'><b>{}</b></span>", // Yellow
        "today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b | %I:%M %p}", //12 hour format
    "format-alt": "яД│  {:%Y-%m-%d яАЧ %H:%M:%S}",
    "interval": 1
  },

  // System
  "custom/system": {
    "format": "юС│",
    "tooltip": false
  },
  "cpu": {
    "format": "яЛЫ {usage: >3}%",
    "on-click": "alacritty -e btop"
  },
  "memory": {
    "format": "яФ╕ {: >3}%",
    "on-click": "alacritty -e btop"
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon8/temp1_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C яЛЗ",
    "format": "яЛЙ  {temperatureC}┬░C"
  },
  "power-profiles-daemon": {
    "format": "{icon} ",
    "tooltip-format": "Profile: {profile}",
    "tooltip": true,
    "format-icons": {
      "default": "ЁЯЧ▓",
      "performance": "ЁЯЧ▓",
      "balanced": "яЙО",
      "power-saver": "ЁЯМ▒"
    }
  },
  // Harddisc space used
  "disk": {
    // "interval": 30,
    "format": "яВа {percentage_used}% ",
    "path": "/"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory"
      // "backlight",
      //"sway/language"
    ]
  },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent: >3}%",
    // "format-icons": ["яЖЕ", "яДС"],
    "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    // "on-scroll-down": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
    "on-scroll-up": "brightnessctl -c backlight set +5%",
    // "on-scroll-up": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
    "on-click": ""
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    "format-charging": "яЧз  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "pulseaudio": {
    // "scroll-step": 5,
    "format": "{icon} {volume: >3}%",
    "format-bluetooth": "{icon} {volume: >3}%",
    "format-muted": "яЪй muted",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яАе",
      "headset": "яАе",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАз", "яАи"]
    },
    "on-click": "pavucontrol",
    // "on-scroll-up": "pamixer -ui 2 && pamixer --get-volume > $SWAYSOCK.wob",
    // "on-scroll-down": "pamixer -ud 2 && pamixer --get-volume > $SWAYSOCK.wob"
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },
  "custom/updates": {
    "format": "яАЩ {}",
    "return-type": "json",
    "interval": 3600,
    "exec": "~/.config/waybar/scripts/check-updates-fedora.sh",
    "on-click": "alacritty -e sh -c 'sudo dnf upgrade; pkill -SIGRTMIN+8 waybar; read -p \"Appuyer sur Entr├йe pour fermer...\"'",
    "signal": 8,
    "exec-on-event": false,
    "min-length": 3
  }
}
