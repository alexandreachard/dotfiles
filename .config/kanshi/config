# Profil bureau — LG UltraGear seul
profile homeoffice {
    output eDP-1 disable
    output DP-4 enable mode 2560x1440@59.951Hz position 0,0 transform normal

    output DP-1 enable mode 1920x1080@60Hz position 320,1440 transform normal
    exec swaymsg "output * bg /home/aachard/.config/backgrounds/mystical-night-in-town.jpg fill"
    exec pkill waybar; sleep 0.5; waybar &
}

# Profil nomade — écran laptop seul
profile nomad {
    output DP-4 disable
    output DP-1 disable
    output eDP-1 enable mode 1920x1080 position 0,0 transform normal

    exec swaymsg "output * bg /home/aachard/.config/backgrounds/mystical-night-in-town.jpg fill"
    exec pkill waybar; sleep 0.5; waybar &
}
